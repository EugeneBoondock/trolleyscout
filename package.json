{
  "name": "trolley-scout",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck:functions": "tsc -p tsconfig.functions.json",
    "verify": "npm run test && npm run lint && npm run build && npm run typecheck:functions",
    "cf:preview": "wrangler pages dev dist",
    "cf:deploy": "wrangler pages deploy dist --project-name trolley-scout",
    "cf:deploy:scout": "wrangler deploy --config wrangler.scout.toml",
    "cf:dev:scout": "wrangler dev --config wrangler.scout.toml --test-scheduled"
  },
  "dependencies": {
    "@fontsource/anton": "^5.2.7",
    "@noble/hashes": "^2.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.3.2",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
